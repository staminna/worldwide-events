PORT=8080
DB_PATH=./eventscraper.db
CITIES_PATH=./configs/cities.yaml
ALLOWED_ORIGIN=*

# Storage backend. Leave DATABASE_URL empty to use the embedded SQLite at
# DB_PATH. Set it to a Postgres/PostGIS DSN to use Postgres instead (required
# for the dekart/geosql map stack) — e.g.
# DATABASE_URL=postgres://eventscraper:eventscraper@localhost:5432/eventscraper
DATABASE_URL=

# How many cities to warm up on startup. 0 = all cities in the catalog (default).
# Set a small number (e.g. 10) if you want to keep startup quick.
WARMUP_CITIES=0

# Only register API-free sources (Eventbrite, Songkick, Luma). Set false to also
# enable Ticketmaster and Meetup when their credentials are set.
FREE_ONLY=true

# Required for the Ticketmaster source. Free key:
# https://developer.ticketmaster.com/api-keys/
TICKETMASTER_API_KEY=

# Required for the Meetup source. Meetup removed their free public REST API.
# A full OAuth client + a paid tier is needed for their GraphQL endpoint.
# Leave empty to skip Meetup.
MEETUP_OAUTH_TOKEN=

# Optional: gate POST /refresh with a bearer token.
ADMIN_TOKEN=

# --- Stealth / pacing (all optional; defaults give a polite, bounded engine) ---
# Max simultaneous (source,city) scrapes. Bounds the MaybeRefresh fan-out.
SCRAPE_CONCURRENCY=4
# Random stagger applied before each scrape unit, in milliseconds.
SCRAPE_MIN_DELAY_MS=300
SCRAPE_MAX_DELAY_MS=1200
# Per-request retries on a block/5xx before giving up (rotates proxy each try).
SCRAPE_MAX_RETRIES=3

# --- Proxies (optional; first non-empty wins; absent = direct connections) ---
# Webshare "Proxy List — Download" URL (tokenized). Refreshed every ~10 min.
# Populate via the proxy-manager skill's `download` action.
WEBSHARE_PROXY_LIST_URL=
# Local file, one proxy per line (host:port:user:pass or http://user:pass@host:port).
PROXY_LIST_PATH=
# Inline list, comma or newline separated (same formats as the file).
PROXIES=
