PORT=8080
DB_PATH=./eventscraper.db
CITIES_PATH=./configs/cities.yaml
ALLOWED_ORIGIN=*

# How many cities to warm up on startup. 0 = all cities in the catalog (default).
# Set a small number (e.g. 10) if you want to keep startup quick.
WARMUP_CITIES=0

# Only register API-free sources (Eventbrite, Songkick, Luma). Set false to also
# enable Ticketmaster and Meetup when their credentials are set.
FREE_ONLY=true

# Required for the Ticketmaster source. Free key:
# https://developer.ticketmaster.com/api-keys/
TICKETMASTER_API_KEY=

# Required for the Meetup source. Meetup removed their free public REST API.
# A full OAuth client + a paid tier is needed for their GraphQL endpoint.
# Leave empty to skip Meetup.
MEETUP_OAUTH_TOKEN=

# Optional: gate POST /refresh with a bearer token.
ADMIN_TOKEN=
